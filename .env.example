# -----------------------------------------------------------------------
# Heisenberg Vault — Environment Variables
# -----------------------------------------------------------------------
# Copy this file to `.env` and fill in your values before starting.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your keys
#   docker-compose up --build
#
# Variables marked [REQUIRED] must be set for the system to function
# correctly in production. Variables marked [OPTIONAL] have safe
# defaults for local development.
#
# NEVER commit your .env file to source control.
# -----------------------------------------------------------------------


# ── Vault Encryption Key ────────────────────────────────────────────────
# [REQUIRED in production]
#
# 32-byte URL-safe base64-encoded Fernet key. This key encrypts every
# protected_payload field in the database. If this key is changed or lost,
# all encrypted records become permanently unreadable.
#
# Generate a new key (run once, store securely):
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# On Render.com: mark as Secret. Render auto-generates this via render.yaml.
# On local dev: set any valid Fernet key, or leave unset to use the built-in
#               DEMO fallback key (insecure — prints a loud warning on startup).
VAULT_MASTER_KEY=REPLACE_WITH_YOUR_FERNET_KEY_HERE


# ── JWT Signing Secret ──────────────────────────────────────────────────
# [REQUIRED in production]
#
# Secret used to sign and verify admin JWT tokens (HS256 algorithm).
# Must be a long, random string. If changed, all existing tokens are
# immediately invalidated.
#
# On Render.com: mark as Secret. Render auto-generates this via render.yaml.
VAULT_JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars


# ── Admin Password ──────────────────────────────────────────────────────
# [OPTIONAL — default: heisenberg2026]
#
# Password for the vault_admin account. Used with POST /api/auth/login.
# Change this before deploying to any public-facing environment.
VAULT_ADMIN_PASSWORD=heisenberg2026


# ── PostgreSQL (Cloud Database) ─────────────────────────────────────────
# [OPTIONAL — falls back to local SQLite vault.db if not set]
#
# When set, the backend connects to a PostgreSQL-compatible database
# instead of the local SQLite file. Supported providers:
#   Supabase: postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres
#   Neon:     postgresql://[user]:[password]@[host]/[dbname]?sslmode=require
#   AWS RDS:  postgresql://[user]:[password]@[host]:5432/[dbname]
#
# The SQLite fallback remains active when this variable is absent.
# POSTGRES_URL=postgresql://user:password@host:5432/dbname


# ── SOC Webhook Alert ───────────────────────────────────────────────────
# [OPTIONAL]
#
# When set, a Discord or Slack webhook POST is fired asynchronously on every
# CRITICAL tier activation (simulating PagerDuty integration). The alert
# includes the tier, caller IP, classification, and LLM narrative.
#
# Discord webhook: Settings → Integrations → Webhooks → Copy Webhook URL
# Slack webhook:   api.slack.com/messaging/webhooks → Create a Webhook
#
# If not set, CRITICAL events are logged internally but no external alert fires.
# SOC_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN


# ── Frontend URL (CORS) ─────────────────────────────────────────────────
# [OPTIONAL — required in production for CORS]
#
# Your deployed frontend URL. Added to the FastAPI CORSMiddleware allowlist
# alongside the localhost and *.vercel.app wildcards already included.
#
# Example: https://heisenberg-vault.vercel.app
# FRONTEND_URL=https://your-frontend.vercel.app


# ── Local LLM — Ollama ─────────────────────────────────────────────────
# [OPTIONAL — recommended for development, no API key required]
#
# Use a locally running Ollama instance as the ELEVATED tier SOC Analyst.
# Install: https://ollama.com — then pull a model: ollama pull llama3.2
#
# Supported models: llama3.2, qwen2.5, mistral, gemma3, phi4, deepseek-r1
# OLLAMA_MODEL and OLLAMA_HOST are checked FIRST in the LLM priority chain.
#
# OLLAMA_MODEL=llama3.2
# OLLAMA_HOST=http://localhost:11434    # default — only set if using non-standard port
#
# In Docker Compose, the backend container reaches Ollama on the host via:
# OLLAMA_HOST=http://host.docker.internal:11434


# ── Local LLM — LM Studio ──────────────────────────────────────────────
# [OPTIONAL — alternative local LLM, no API key required]
#
# Use any model loaded in LM Studio's local server as the SOC Analyst.
# Install: https://lmstudio.ai — load a model, start the local server.
#
# LM_STUDIO_MODEL=your-model-name
# LM_STUDIO_HOST=http://localhost:1234    # default LM Studio port


# ── Remote LLM APIs ────────────────────────────────────────────────────
# [OPTIONAL — checked in priority order after local backends]
#
# Only one key is needed. The system uses the first non-empty key it finds,
# walking the registry in this order: Kimi → Groq → OpenRouter → OpenAI.
#
# For development/demo, Groq is recommended (fast, free, no credit card):
#   Sign up: https://console.groq.com
#   Model:   llama-3.3-70b-versatile (used automatically)

# Kimi — moonshot-v1-8k [FREE credits on signup — platform.moonshot.cn]
KIMI_API_KEY=

# Groq — llama-3.3-70b-versatile [FREE tier — console.groq.com]
GROQ_API_KEY=

# OpenRouter — qwen/qwq-32b:free [FREE tier — openrouter.ai]
OPENROUTER_API_KEY=

# OpenAI — gpt-4o-mini [PAID — platform.openai.com]
OPENAI_API_KEY=

# -----------------------------------------------------------------------
# If ALL LLM keys are blank and no local model is configured, the system
# automatically uses a mathematical heuristic fallback:
#   sweep_ratio = records_requested / total_vault_records
#   if sweep_ratio >= 0.30 → MASS_SURVEILLANCE
#   else                   → SURGICAL
#
# The heuristic requires zero external dependencies and always produces
# a deterministic result. The ELEVATED tier is fully functional without
# any LLM configuration.
# -----------------------------------------------------------------------
