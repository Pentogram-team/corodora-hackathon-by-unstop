# -----------------------------------------------------------------------
# Heisenberg Vault — Environment Variables
# -----------------------------------------------------------------------
# Copy this file to `.env` and fill in your values.
#
# ── Vault encryption key ────────────────────────────────────────────────
# Generate a fresh Fernet key:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

VAULT_MASTER_KEY=REPLACE_WITH_YOUR_FERNET_KEY_HERE

# ── LOCAL LLM (no API key, no internet — recommended for dev) ──────────
# Option A: Ollama  →  https://ollama.com
#   Install, then run:  ollama pull llama3.2
#   Supported models: llama3.2, qwen2.5, mistral, gemma3, phi4, deepseek-r1
OLLAMA_MODEL=llama3.2
# OLLAMA_HOST=http://localhost:11434   # optional, this is the default

# Option B: LM Studio  →  https://lmstudio.ai
#   Load any model in LM Studio, start the local server, then set:
# LM_STUDIO_MODEL=your-model-name
# LM_STUDIO_HOST=http://localhost:1234

# ── REMOTE LLM APIs (free-tier, used when no local model is set) ────────
# Groq (llama-3.3-70b-versatile) — always free, ultra-fast
GROQ_API_KEY=

# Kimi (moonshot-v1-8k) — free credits on signup
KIMI_API_KEY=

# OpenRouter (qwen/qwq-32b:free) — free-tier Qwen 32B
OPENROUTER_API_KEY=

# OpenAI (gpt-4o-mini) — paid, last resort
OPENAI_API_KEY=

# ── JWT signing secret used by main.py ─────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
